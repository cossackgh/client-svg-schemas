{
  "name": "@svgic/core",
  "version": "0.1.2",
  "description": "Interactive SVG schema client — embed, bind data, and handle events on SVG layers",
  "type": "module",
  "main": "./dist/svgic.cjs",
  "module": "./dist/svgic.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/svgic.js",
      "require": "./dist/svgic.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./vue": {
      "import": "./dist/vue.js",
      "types": "./dist/adapters/vue/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/adapters/react/index.d.ts"
    },
    "./plugins/zoom": {
      "import": "./dist/plugins/zoom.js",
      "types": "./dist/plugins/zoom/index.d.ts"
    },
    "./plugins/debug": {
      "import": "./dist/plugins/debug.js",
      "types": "./dist/plugins/debug/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite serve playground --config vite.playground.config.ts",
    "build": "vite build",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "svg",
    "interactive",
    "schema",
    "map",
    "viewer",
    "layers"
  ],
  "author": "Dmitry Yagupov",
  "repository": {
    "type": "git",
    "url": "https://github.com/cossackgh/client-svg-schemas.git"
  },
  "homepage": "https://github.com/cossackgh/client-svg-schemas#readme",
  "license": "MIT",
  "peerDependencies": {
    "react": ">=17.0.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "vue": { "optional": true }
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-vue": "^6.0.5",
    "jsdom": "^29.0.1",
    "typescript": "^5.4.0",
    "vite": "^8.0.7",
    "vite-plugin-dts": "^3.9.0",
    "vitest": "^4.1.3",
    "vue": "^3.4.0",
    "vue-tsc": "^2.0.0"
  }
}
