{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "svgic": ["./src/index.ts"],
      "svgic/plugins/zoom": ["./src/plugins/zoom/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "playground", "tests"]
}
